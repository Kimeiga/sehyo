# Copy this file to .dev.vars and fill in your actual values
# DO NOT commit .dev.vars to version control

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Optional. If unset, Better Auth derives the redirect URI from the request
# host (`${origin}/api/auth/callback/google`), which is what you usually want
# for local dev. Only set this to pin a specific URI (e.g. for production).
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/callback/google


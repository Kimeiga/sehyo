engine-strict=true
# better-auth@1.6.10 declares a peer of drizzle-orm@^0.45.2 but we run
# 0.44.x; npm 7+ refuses to install with that conflict by default. The
# app only uses drizzle-orm transitively via better-auth, so the older
# drizzle works in practice. Without this flag the CI `npm install`
# step ("rm -rf node_modules package-lock.json && npm install") fails
# on every push to main.
legacy-peer-deps=true
